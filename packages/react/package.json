{
  "name": "@reactive-agent/react",
  "version": "0.1.0",
  "description": "React hooks for ReactiveAgents — useAgent, useAgentResult, streaming support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sol-dev-44/reactive-agents.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/sol-dev-44/reactive-agents#readme",
  "bugs": {
    "url": "https://github.com/sol-dev-44/reactive-agents/issues"
  },
  "peerDependencies": {
    "@reactive-agent/core": "^0.1.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@reactive-agents/core": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@testing-library/react": "^16.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0"
  }
