{
  "name": "@reactive-agents/react",
  "version": "0.1.0",
  "description": "React hooks for ReactiveAgents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
